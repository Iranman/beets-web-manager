plugins: fetchart embedart convert scrub replaygain lastgenre chroma lyrics mbsync musicbrainz discogs deezer listenbrainz ftintitle fromfilename duplicates missing smartplaylist mbsubmit unimported plexsync discpath
pluginpath: /config/beetsplug
directory: /data/media/music
library: /config/musiclibrary.blb
art_filename: albumart
threaded: yes
original_date: no
per_disc_numbering: yes

convert:
    auto: no
    ffmpeg: /usr/bin/ffmpeg
    opts: -ab 320k -ac 2 -ar 48000
    max_bitrate: 320
    threads: 1

paths:
    default: "$albumartist%if{$mb_albumartistid, ($mb_albumartistid),}/$album (%left{$year,4})%if{$mb_releasegroupid, {$mb_releasegroupid$}}/$albumartist - $album - %right{00$track,2} - $title"
    singleton: "$albumartist%if{$mb_albumartistid, ($mb_albumartistid),}/$album (%left{$year,4})%if{$mb_releasegroupid, {$mb_releasegroupid$}}/$artist - $album - %right{00$track,2} - $title ($disc)%if{$mb_artistid,{$mb_artistid$}}"
    comp: "$albumartist%if{$mb_albumartistid, ($mb_albumartistid),}/$album (%left{$year,4})%if{$mb_releasegroupid, {$mb_releasegroupid$}}/$albumartist - $album - %right{00$track,2} - $title"
    albumtype_soundtrack: Soundtracks/$album (%left{$year,4})/$albumartist - $album - %right{00$track,2} - $title
    albumtype_single: "$albumartist%if{$mb_albumartistid, ($mb_albumartistid),}/%if{$year,%left{$year,4} - }$album [Single]/%right{00$track,2} - $title"

import:
    write: yes
    copy: yes
    move: no
    resume: ask
    incremental: yes
    quiet_fallback: skip
    timid: no
    log: /config/beet.log

lastgenre:
    auto: yes
    source: album

embedart:
    auto: yes

fetchart:
    auto: yes

replaygain:
    auto: no
    command: mp3gain

scrub:
    auto: yes

replace:
    '^\.': _
    '[\x00-\x1f]': _
    '[<>:"\?\*\|]': _
    '[\xE8-\xEB]': e
    '[\xEC-\xEF]': i
    '[\xE2-\xE6]': a
    '[\xF2-\xF6]': o
    '[\xF8]': o
    '\.$': _
    '\s+$': ''

musicbrainz:
    genres: yes
    extra_tags: [year, catalognum, country, media, label]
    external_ids:
        discogs: yes
        spotify: yes
        bandcamp: yes
    search_limit: 10

lyrics:
    auto: yes
    sources: genius musixmatch

# Set discogs.user_token via config secrets or leave blank to disable Discogs lookups.
discogs:
    user_token: ""
    username: changeme
    index_tracks: no
    append_style_genre: yes
    extra_tags: [year, catalognum, country, label]
    search_limit: 10

deezer:
    search_limit: 10

duplicates:
    keys: [mb_trackid, mb_albumid]
    count: yes
    strict: yes

ftintitle:
    auto: yes
    drop: no
    format: "feat. {0}"

# Set listenbrainz.token via config secrets or leave blank to disable ListenBrainz submission.
listenbrainz:
    token: ""
    username: changeme

mbsubmit:
    threshold: medium
    format: $track. $title - $artist ($length)

missing:
    count: yes
    total: yes

smartplaylist:
    auto: yes
    playlist_dir: /data/media/music/playlists
    relative_to: /data/media/music
    forward_slash: yes
    playlists:
        - name: all-tracks.m3u
          query: ''
        - name: soundtracks.m3u
          query: 'albumtype:soundtrack'
        - name: singles.m3u
          query: 'albumtype:single'
        - name: compilations.m3u
          query: 'comp:true'
        - name: flac-tracks.m3u
          query: 'format:FLAC'

unimported:
    ignore_extensions: jpg jpeg png gif bmp log m3u m3u8 pls sfv cue nfo txt pdf
    ignore_subdirectories: Non-Album Compilations Soundtracks playlists

# Set plex.host/token to match your PLEX_URL / PLEX_TOKEN environment values.
plex:
    host: change-me.example.com
    port: 32400
    token: ""
    library_name: Music

# ── Plugin: beets-aisauce ─────────────────────────────────────────────────
# AI metadata cleanup — runs after import to normalize/enrich tags via OpenAI
# Commands: beet aisauce [query]
aisauce:
    mode: metadata_cleanup
    auto: no
    providers:
        - id: openai
          model: gpt-4o-mini
          api_key: ""
