# Required owner/admin authentication
BEETS_WEB_AUTH_TOKEN=changeme
BEETS_WEB_PASSWORD=
BEETS_WEB_USERNAME=admin
BEETS_WEB_AUTH_DISABLED=0
BEETS_WEB_AUTH_MIN_LENGTH=32
BEETS_TRUSTED_PROXIES=
BEETS_OUTBOUND_ALLOWLIST=192.168.0.250:32400,192.168.0.250:8686,bgutil-provider:4416,slskd:5030

# Core Beets paths
BEETS_LIBRARY=/config/musiclibrary.blb
BEETS_CONFIG=/config/config.yaml
BEETS_LOG=/config/beet.log
WEBCONTROL_PORT=8337

# AI provider keys
OPENAI_API_KEY=
OPENROUTER_API_KEY=
AI_API_KEY=

# Plex and Arr services
PLEX_URL=http://192.168.0.250:32400
PLEX_TOKEN=
LIDARR_URL=http://192.168.0.250:8686
LIDARR_API_KEY=
RADARR_API_KEY=
SONARR_API_KEY=
PROWLARR_API_KEY=

# Music metadata providers
ACOUSTID_API_KEY=
ACOUSTID_KEY=
DISCOGS_TOKEN=
DISCOGS_USER_TOKEN=
LISTENBRAINZ_TOKEN=

# SLSKD and Soulseek
SLSKD_SLSK_USERNAME=changeme
SLSKD_SLSK_PASSWORD=changeme
SLSKD_API_KEY=
SLSKD_API_KEY_FILE=/config/slskd_api_key

# Spotify playlist parsing
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# yt-dlp and direct-source helpers
YTDLP_COOKIE_FILE=/config/yt-dlp/cookies.txt
YTDLP_ALLOW_BROWSER_COOKIES=0
YTDLP_NETRC_FILE=/config/.netrc
YTDLP_PO_PROVIDER_URL=http://bgutil-provider:4416
YTDLP_JS_RUNTIMES=deno,node,quickjs
YTDLP_REMOTE_COMPONENTS=
YTDLP_INSTALL_DENO=0
YTDLP_INSTALL_SYSTEM_JS_RUNTIME=0
SPOTIFLAC_AUTO_INSTALL=0
SPOTIFLAC_CMD=

# Docker service credentials
PUID=1000
PGID=1000
BEETS_UID=1000
BEETS_GID=1000
DIGARR_INITIAL_PASSWORD=changeme
POSTGRES_PASSWORD=changeme
